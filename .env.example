# Referência de configuração do iGuard. Não coloque segredos neste arquivo.
# O Next.js lê esta variável no ambiente do app `apps/web` ou na plataforma de deploy.
NEXT_PUBLIC_DEMO_MODE=false

# A API (apps/api) lê esta variável para liberar CORS.
# Lista de origens permitidas, separadas por vírgula. Espaços são removidos
# e valores vazios são ignorados automaticamente. Nunca use "*" em produção.
# Exemplo: CORS_ORIGIN=https://app.iguard.io,https://admin.iguard.io
CORS_ORIGIN=
