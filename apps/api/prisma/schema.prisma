generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  MASTER
  OWNER
  ADMIN
  OPERATOR
  VIEWER
}

enum DeviceType {
  HTTP
  TCP
  PING
  RTSP
  CAMERA
  DVR
  NVR
  ROUTER
  MIKROTIK
  ACCESS_CONTROL
  FACIAL
  MODEM
  OTHER
}

enum DeviceStatus {
  ONLINE
  ATTENTION
  OFFLINE
  PAUSED
}

enum IncidentStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  document  String?
  email     String?
  phone     String?
  active    Boolean  @default(true)

  users     User[]
  customers Customer[]
  devices   Device[]
  incidents Incident[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  email        String   @unique
  passwordHash String?
  role         UserRole @default(ADMIN)
  active       Boolean  @default(true)

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model Customer {
  id        String  @id @default(cuid())
  tenantId  String
  name      String
  document  String?
  email     String?
  phone     String?
  active    Boolean @default(true)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sites   Site[]
  devices Device[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model Site {
  id         String  @id @default(cuid())
  tenantId   String
  customerId String
  name       String
  address    String?
  active     Boolean @default(true)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  devices  Device[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([customerId])
}

model Device {
  id          String       @id @default(cuid())
  tenantId    String
  customerId  String?
  siteId      String?
  name        String
  type        DeviceType
  host        String
  port        Int?
  path        String?
  status      DeviceStatus @default(ATTENTION)
  enabled     Boolean      @default(true)

  checkIntervalSec Int @default(60)
  timeoutMs        Int @default(5000)
  retries          Int @default(3)

  lastSeenAt       DateTime?
  lastCheckedAt    DateTime?
  lastLatencyMs    Int?

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  site     Site?     @relation(fields: [siteId], references: [id], onDelete: SetNull)

  checks    Check[]
  incidents Incident[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([customerId])
  @@index([siteId])
  @@index([status])
  @@index([enabled])
}

model Check {
  id          String   @id @default(cuid())
  deviceId    String
  success     Boolean
  latencyMs   Int?
  statusCode  Int?
  error       String?
  checkedAt   DateTime @default(now())

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@index([checkedAt])
  @@index([success])
}

model Incident {
  id          String         @id @default(cuid())
  tenantId    String
  deviceId    String
  title       String
  description String?
  status      IncidentStatus @default(OPEN)
  openedAt    DateTime       @default(now())
  resolvedAt  DateTime?

  tenantRef Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([deviceId])
  @@index([status])
}
