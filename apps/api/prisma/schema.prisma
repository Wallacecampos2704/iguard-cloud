generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountStatus {
  TRIAL
  ACTIVE
  TRIAL_EXPIRED
  BLOCKED
  CANCELED
}

enum DeviceStatus {
  ONLINE
  WARNING
  OFFLINE
  UNKNOWN
  MAINTENANCE
}

enum DeviceType {
  ROUTER
  MIKROTIK
  CAMERA_IP
  DVR_NVR
  FACIAL
  ACCESS_CONTROLLER
  SERVER
  INTERNET_LINK
  SIP_GATEWAY
  ALARM
  OTHER
}

enum CheckType {
  HTTP
  HTTPS
  TCP_PORT
  PING
  RTSP
  SIP
  DNS
  WIREGUARD
  MANUAL
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum IncidentSource {
  MANUAL_CHECK
  BATCH_CHECK
  MONITORING_CRON
}

enum IncidentCategory {
  INTERNET
  POWER
  DEVICE
  DVR
  NVR
  FACIAL
  CAMERA
  ROUTER
  SWITCH
  SERVER
  UNKNOWN
}

enum NotificationChannel {
  EMAIL
  TELEGRAM
  WHATSAPP
  SMS
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum NotificationType {
  DEVICE_OFFLINE
  DEVICE_ONLINE
  DEVICE_WARNING
  INCIDENT_OPENED
  INCIDENT_RESOLVED
  TEST
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  BLOCKED
  CANCELED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
  REFUNDED
}

enum UserRole {
  MASTER
  ADMIN
  OPERATOR
  VIEWER
}

model Organization {
  id          String        @id @default(uuid())
  name        String
  type        String        @default("INTEGRATOR")
  document    String?
  phone       String?
  city        String?
  state       String?
  plan        String        @default("trial")
  deviceLimit Int           @default(3)
  status      AccountStatus @default(TRIAL)
  trialEndsAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  customers               Customer[]
  sites                   Site[]
  devices                 Device[]
  checkResults            CheckResult[]
  incidents               Incident[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  notificationContacts    NotificationContact[]
  alertTemplates          AlertTemplate[]
  subscriptions           Subscription[]
  payments                Payment[]
  users                   User[]
}

model Customer {
  id              String   @id @default(uuid())
  organizationId  String
  name            String
  document        String?
  responsibleName String?
  phone           String?
  email           String?
  notes           String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization            Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sites                   Site[]
  devices                 Device[]
  incidents               Incident[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
}

model Site {
  id             String   @id @default(uuid())
  organizationId String
  customerId     String
  name           String
  type           String?
  address        String?
  city           String?
  state          String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer      Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  devices       Device[]
  incidents     Incident[]
  notifications Notification[]
}

model Device {
  id                   String       @id @default(uuid())
  organizationId       String
  customerId           String
  siteId               String
  name                 String
  deviceType           DeviceType   @default(OTHER)
  manufacturer         String?
  model                String?
  host                 String
  port                 Int?
  checkType            CheckType    @default(HTTP)
  checkIntervalSeconds Int          @default(60)
  currentStatus        DeviceStatus @default(UNKNOWN)
  lastCheckedAt        DateTime?
  responseTimeMs       Int?
  monitoringEnabled    Boolean      @default(true)
  notes                String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer      Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  site          Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  checkResults  CheckResult[]
  incidents     Incident[]
  notifications Notification[]
}

model CheckResult {
  id             String       @id @default(uuid())
  organizationId String
  deviceId       String
  status         DeviceStatus
  responseTimeMs Int?
  errorMessage   String?
  checkType      CheckType
  source         String       @default("SIMULATED")
  rawPayload     Json?
  checkedAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  device       Device       @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model Incident {
  id             String            @id @default(uuid())
  organizationId String
  customerId     String?
  siteId         String?
  deviceId       String?
  title          String
  description    String?
  severity       IncidentSeverity  @default(MEDIUM)
  status         IncidentStatus    @default(OPEN)
  previousStatus DeviceStatus      @default(UNKNOWN)
  currentStatus  DeviceStatus      @default(UNKNOWN)
  startedAt      DateTime          @default(now())
  resolvedAt     DateTime?
  lastSeenAt     DateTime          @default(now())
  source         IncidentSource    @default(MANUAL_CHECK)
  category       IncidentCategory?
  probableCause  String?
  aiSummary      String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer      Customer?      @relation(fields: [customerId], references: [id])
  site          Site?          @relation(fields: [siteId], references: [id])
  device        Device?        @relation(fields: [deviceId], references: [id])
  notifications Notification[]

  @@index([deviceId, status])
  @@index([status, startedAt])
  @@index([resolvedAt])
}

model Notification {
  id                String              @id @default(uuid())
  organizationId    String
  customerId        String?
  siteId            String?
  deviceId          String?
  incidentId        String?
  channel           NotificationChannel
  type              NotificationType
  status            NotificationStatus  @default(PENDING)
  recipient         String?
  subject           String?
  message           String
  providerMessageId String?
  errorMessage      String?
  attemptCount      Int                 @default(0)
  sentAt            DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deduplicationKey  String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  site         Site?        @relation(fields: [siteId], references: [id], onDelete: SetNull)
  device       Device?      @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  incident     Incident?    @relation(fields: [incidentId], references: [id], onDelete: SetNull)

  @@unique([channel, deduplicationKey])
  @@index([organizationId, createdAt])
  @@index([customerId, createdAt])
  @@index([deviceId, createdAt])
  @@index([status, createdAt])
  @@index([channel, createdAt])
  @@index([type, createdAt])
}

model NotificationPreference {
  id                       String   @id @default(uuid())
  organizationId           String
  customerId               String?  @unique
  telegramEnabled          Boolean  @default(false)
  emailEnabled             Boolean  @default(false)
  whatsappEnabled          Boolean  @default(false)
  smsEnabled               Boolean  @default(false)
  alertOnOffline           Boolean  @default(true)
  alertOnRecovery          Boolean  @default(true)
  alertOnWarning           Boolean  @default(true)
  confirmationDelaySeconds Int      @default(0)
  cooldownMinutes          Int      @default(0)
  quietHoursEnabled        Boolean  @default(false)
  quietHoursStart          String?
  quietHoursEnd            String?
  timezone                 String   @default("America/Sao_Paulo")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model NotificationContact {
  id                    String   @id @default(uuid())
  organizationId        String
  name                  String
  role                  String?
  whatsapp              String?
  email                 String?
  telegramChatId        String?
  receivesCriticalAlert Boolean  @default(true)
  receivesRecoveryAlert Boolean  @default(true)
  receivesBillingAlert  Boolean  @default(false)
  active                Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model AlertTemplate {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  audience       String
  template       String
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                        String             @id @default(uuid())
  organizationId            String
  plan                      String
  status                    SubscriptionStatus @default(TRIAL)
  mercadoPagoSubscriptionId String?
  trialStartsAt             DateTime?
  trialEndsAt               DateTime?
  currentPeriodStartsAt     DateTime?
  currentPeriodEndsAt       DateTime?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payments     Payment[]
}

model Payment {
  id                   String        @id @default(uuid())
  organizationId       String
  subscriptionId       String?
  amount               Decimal       @db.Decimal(10, 2)
  currency             String        @default("BRL")
  status               PaymentStatus @default(PENDING)
  mercadoPagoPaymentId String?
  paymentMethod        String?
  paidAt               DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
}

model User {
  id             String    @id @default(uuid())
  organizationId String?
  email          String    @unique
  passwordHash   String
  name           String
  role           UserRole
  active         Boolean   @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sessions     Session[]

  @@index([organizationId])
}

model Session {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String   @unique
  userAgent  String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())
  expiresAt  DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
